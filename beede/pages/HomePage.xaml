<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:beede.Converters"
             x:Class="beede.Pages.HomePage"
             Title="HOME">

	<ContentPage.Resources>
		<converters:IncomeToColorConverter x:Key="IncomeToColor" />
	</ContentPage.Resources>

	<VerticalStackLayout Spacing="20" Padding="20">

		<Label Text="HOME" FontSize="30" HorizontalOptions="Center" />

		<Label Text="Number of recorded bills :" />
		<Label x:Name="RecordedBillsLabel" Text="0" FontSize="20" />

		<Label Text="The amount saved :" />
		<Label x:Name="SavedAmountLabel" Text="$0.00" FontSize="20" />

		<Button Text="NEW" Clicked="OnNewClicked" />

		<Label Text="搜索账单" FontSize="18" FontAttributes="Bold" />
		<SearchBar x:Name="SearchBar" Placeholder="输入描述关键词..." TextChanged="OnSearchTextChanged" />

		<!-- 搜索结果列表 -->
		<Label Text="搜索结果：" FontSize="16" FontAttributes="Bold" />
		<CollectionView x:Name="SearchResultsView" HeightRequest="300">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Grid Padding="5" ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto">
						<Label Text="{Binding Description}" Grid.Row="0" Grid.Column="0" FontAttributes="Bold" />
						<Label Text="{Binding Date, StringFormat='{0:yyyy-MM-dd}'}" Grid.Row="1" Grid.Column="0"
                               FontSize="12" TextColor="Gray" />
						<Label Text="{Binding Amount, StringFormat='{0:C}'}" Grid.Row="0" Grid.Column="1"
                               TextColor="{Binding IsIncome, Converter={StaticResource IncomeToColor}}" />
						<Button Text="删除" Grid.Row="0" Grid.Column="2" Clicked="OnDeleteSearchResult"
                                CommandParameter="{Binding .}" BackgroundColor="Red" TextColor="White" />
					</Grid>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

	</VerticalStackLayout>

</ContentPage>