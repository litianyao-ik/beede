<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="beede.Pages.LoginPage"
             Title="Login">
    <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
        <Image Source="avatar.png" HeightRequest="100" HorizontalOptions="Center" />
        <Label Text="Login" FontSize="24" HorizontalOptions="Center" />
        <Entry x:Name="UserNameEntry" Placeholder="User Name" />
        <Entry x:Name="PasswordEntry" Placeholder="Password" IsPassword="True" />
        <Button Text="Login" Clicked="OnLoginClicked" />
    </VerticalStackLayout>
</ContentPage>