<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="beede.Pages.BillPage"
             Title="BILL">

	<Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="*,*" Padding="20" RowSpacing="15">

		<!-- 标题 -->
		<Label Grid.Row="0" Grid.ColumnSpan="2" Text="BILL" FontSize="30" HorizontalOptions="Center" />

		<!-- Net Income 显示 -->
		<Label Grid.Row="1" Grid.ColumnSpan="2" Text="Net income :" />
		<Label Grid.Row="1" Grid.ColumnSpan="2" x:Name="NetIncomeLabel" Text="$0.00" FontSize="20"
               HorizontalOptions="End" VerticalOptions="End" />

		<!-- 收入列表标题 -->
		<Label Grid.Row="2" Grid.Column="0" Text="收入" FontSize="18" FontAttributes="Bold"
               HorizontalOptions="Center" VerticalOptions="Start" />

		<!-- 支出列表标题 -->
		<Label Grid.Row="2" Grid.Column="1" Text="支出" FontSize="18" FontAttributes="Bold"
               HorizontalOptions="Center" VerticalOptions="Start" />

		<!-- 收入列表 -->
		<CollectionView Grid.Row="3" Grid.Column="0" x:Name="IncomeListView"
                        SelectionMode="Single" SelectionChanged="OnBillSelected">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Grid Padding="5" ColumnDefinitions="*,Auto">
						<Label Text="{Binding Description}" Grid.Column="0" />
						<Label Text="{Binding Amount, StringFormat='+{0:C}'}" Grid.Column="1"
                               TextColor="Green" />
					</Grid>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

		<!-- 支出列表 -->
		<CollectionView Grid.Row="3" Grid.Column="1" x:Name="ExpenseListView"
                        SelectionMode="Single" SelectionChanged="OnBillSelected">
			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Grid Padding="5" ColumnDefinitions="*,Auto">
						<Label Text="{Binding Description}" Grid.Column="0" />
						<Label Text="{Binding Amount, StringFormat='-{0:C}'}" Grid.Column="1"
                               TextColor="Red" />
					</Grid>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

	</Grid>

</ContentPage>